# Copy to terraform.tfvars and edit.

# REQUIRED: public git repo that Airflow's git-sync pulls DAGs from —
# this repo's canonical home (use your own fork if you change the DAGs).
dags_repo_url = "https://github.com/elveli/eks-airflow-kubeflow-demo.git"

# region       = "us-east-1"
# project_name = "afkf-demo"

# Keep this current! Old versions fall into EKS "extended support" at
# $0.60/h instead of $0.10/h.
# cluster_version = "1.33"

# Set true for private subnets + a single NAT gateway (+~$0.045/h + data).
# enable_nat = false

# Restrict the public API endpoint to your own IP if you want:
# api_allowed_cidrs = ["203.0.113.7/32"]
